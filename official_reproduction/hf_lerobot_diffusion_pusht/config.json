    },
    "observation.state": {
      "shape": [
        2
      ],
      "type": "STATE"
    }
  },
  "kernel_size": 5,
  "n_action_steps": 8,
  "n_groups": 8,
  "n_obs_steps": 2,
  "device": "cuda",
  "use_amp": false,
